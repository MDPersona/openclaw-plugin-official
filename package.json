{
  "name": "mdpersona-plugin",
  "version": "1.0.3",
  "description": "Sync your MDPersona preference profiles into OpenClaw automatically",
  "type": "module",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "mdpersona",
    "profiles",
    "preferences",
    "personalization"
  ],
  "author": {
    "name": "MDPersona",
    "url": "https://mdpersona.com"
  },
  "license": "MIT",
  "homepage": "https://mdpersona.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdpersona/openclaw-plugin-official.git"
  },
  "bugs": {
    "url": "https://github.com/mdpersona/openclaw-plugin-official/issues"
  },
  "openclaw": {
    "id": "mdpersona",
    "extensions": [
      "./src/index.ts"
    ]
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "src",
    "dist",
    "openclaw.plugin.json",
    "icon.svg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
